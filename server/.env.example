# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# For Gmail, generate an App Password:
#   Google Account → Security → 2-Step Verification → App Passwords
#   App name: "GenAI Learning", copy the 16-char password below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=GenAI Learning <your-gmail@gmail.com>

# ── URLs ──────────────────────────────────────────────────────────────────────
# APP_URL  = where this Express server is reachable (used in verification links)
# FRONTEND_URL = where the Vite dev server runs (for post-verify redirect)
# Production: set these to your deployed URLs
# APP_URL  = your Railway server URL, e.g. https://genai-learning.up.railway.app
# FRONTEND_URL = your Vercel URL, e.g. https://genai-learning-dapp.vercel.app
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5175

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_KEY=change-me-to-something-secret

# ── Blockchain ────────────────────────────────────────────────────────────────
# Default values point at the Hardhat local node (npx hardhat node).
# PRIVATE_KEY is Hardhat account #0 — never use on mainnet.
RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── Contract addresses (optional override — normally read from deployed_addresses.json) ──
# Set these if you deployed to a non-default chain or renamed the ignition module.
CONTRACT_ADDRESS=
COURSE_PAYMENT_ADDRESS=
