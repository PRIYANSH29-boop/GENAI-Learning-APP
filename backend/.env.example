# Sepolia testnet — get a free RPC URL from https://alchemy.com
# Set these via Hardhat vars, NOT a .env file:
#   npx hardhat vars set SEPOLIA_RPC_URL https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
#   npx hardhat vars set SEPOLIA_PRIVATE_KEY 0xYOUR_WALLET_PRIVATE_KEY
#
# Then deploy:
#   npx hardhat ignition deploy ignition/modules/LearningTracker.ts --network sepolia
#   npx hardhat ignition deploy ignition/modules/CoursePayment.ts --network sepolia
#
# After deploying, copy the addresses into server/.env:
#   CONTRACT_ADDRESS=0x...
#   COURSE_PAYMENT_ADDRESS=0x...
